<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/face_main_color"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:scrollbars="none"
    tools:context="com.hiface.demo.FaceAINaviActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingVertical="24dp">

        <!-- Header Section -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HiFaceSDK"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/top_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@id/tv_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_title">

            <ImageView
                android:id="@+id/system_info"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="5dp"
                android:src="@drawable/info_icon_24"
                app:tint="@color/white" />

            <ImageView
                android:id="@+id/share_face"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="5dp"
                android:src="@drawable/share"
                app:tint="@color/white" />

            <LinearLayout
                android:id="@+id/update_layout"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_rect_line"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/update"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/update_face_app"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Camera Configuration Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/camera_selector_card"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="32dp"
            android:paddingHorizontal="5dp"
            app:layout_constraintTop_toBottomOf="@id/tv_title">

            <!-- 文字前面加一个切换图标 -->
            <TextView
                android:id="@+id/camera_type_select"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/camera_type_background"
                android:drawableStart="@android:drawable/ic_popup_sync"
                android:drawablePadding="9dp"
                android:drawableTint="@color/white"
                android:gravity="center_vertical"
                android:paddingHorizontal="15dp"
                android:paddingVertical="7dp"
                android:text="@string/camera_type_system"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Features Menu List -->
        <LinearLayout
            android:id="@+id/features_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/camera_selector_card">

            <!-- Face Verify -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/face_verify"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_rect_line"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/iv_verify_icon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_slideshow"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/face_verify_1vs1"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/iv_arrow1"
                    app:layout_constraintStart_toEndOf="@id/iv_verify_icon"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/iv_arrow1"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:rotation="180"
                    android:src="@drawable/ic_arrow_back_24"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/half_white" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Face Search -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/face_search"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_rect_line"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/iv_search_icon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/white" />

                <TextView
                    android:id="@+id/change_base_img"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/face_search"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/iv_arrow2"
                    app:layout_constraintStart_toEndOf="@id/iv_search_icon"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/iv_arrow2"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:rotation="180"
                    android:src="@drawable/ic_arrow_back_24"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/half_white" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Liveness Detection -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/liveness_detection"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_rect_line"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/iv_live_icon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/liveness_detection"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/iv_arrow3"
                    app:layout_constraintStart_toEndOf="@id/iv_live_icon"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/iv_arrow3"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:rotation="180"
                    android:src="@drawable/ic_arrow_back_24"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/half_white" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Static Face 1:1 Comparison -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/two_face_verify"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_rect_line"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/iv_two_face_icon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/two_face_image_verify"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/iv_arrow4"
                    app:layout_constraintStart_toEndOf="@id/iv_two_face_icon"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/iv_arrow4"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:rotation="180"
                    android:src="@drawable/ic_arrow_back_24"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/half_white" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Camera Parameter Settings -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/params_setting"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_rect_line"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/iv_params_icon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_preferences"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/parameter_setting"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/iv_arrow5"
                    app:layout_constraintStart_toEndOf="@id/iv_params_icon"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/iv_arrow5"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:rotation="180"
                    android:src="@drawable/ic_arrow_back_24"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/half_white" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>

        <!-- Footer Section -->
        <TextView
            android:id="@+id/more_about_me"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:padding="16dp"
            android:text="@string/about_us"
            android:textColor="@color/half_white"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/features_container" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
