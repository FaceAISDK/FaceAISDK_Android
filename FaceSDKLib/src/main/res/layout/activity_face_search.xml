<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:customAttr="http://schemas.android.com/apk/res-auto"
    tools:context=".SysCamera.search.FaceSearch1NActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_camerax"
        android:layout_margin="30dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Custom your Face Verify UI-->
    <com.sdk.hiface.search.GraphicOverlay
        android:id="@+id/graphicOverlay"
        android:layout_margin="30dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- 可以替换成你自己的UI样式,需要 FaceCoverView 源码联系对接工程师-->
    <com.hiface.demo.base.view.FaceCoverView
        android:id="@+id/face_cover"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        customAttr:background_color="@color/half_white"
        customAttr:show_progress="false"
        customAttr:tip_text_bg_color="@color/face_main_color"
        customAttr:tip_text_color="@color/white"
        customAttr:tip_text_size="19sp" />

    <ImageView
        android:id="@+id/close"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="7dp"
        android:layout_marginTop="15dp"
        android:padding="10dp"
        android:src="@drawable/ic_arrow_back_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>